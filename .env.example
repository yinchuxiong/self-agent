APP_ENV=development
APP_SECRET_KEY=change-me
DATABASE_URL=sqlite+aiosqlite:///./data/self_agent.db
QDRANT_URL=http://localhost:6333
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_WORKSPACE_DIR=E:/selfAgent
LOG_RETENTION_DAYS=90

# LangSmith (tracing & observability)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=self-agent
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# SSL verification for LLM API calls — set to false if behind SSL-intercepting proxy
LLM_SSL_VERIFY=true

# LangGraph Checkpointer
CHECKPOINT_BACKEND=sqlite
# CHECKPOINT_DB_URL=postgresql://self_agent:password@postgres:5432/self_agent_checkpoints

